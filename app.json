{
  "expo": {
    "name": "LoopTidy",
    "slug": "looptidy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "looptidy",
    "userInterfaceStyle": "automatic",
    "description": "Track follow-ups, promises, waiting items, and decisions so open loops stop slipping through.",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F6F8FB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hailehaile.looptidy",
      "buildNumber": "5",
      "infoPlist": {
        "CFBundleDisplayName": "LoopTidy",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.hailehaile.looptidy",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#F6F8FB",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F6F8FB",
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "dark": {
            "backgroundColor": "#0B1220",
            "image": "./assets/splash-icon.png",
            "imageWidth": 220
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "94946304-cc30-4af8-b493-d999c6bb911b"
      }
    },
    "owner": "astrohaile"
  }
}
